{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shows",
  "version": "0.3.0",
  "identifier": "com.christianpayne.shows",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "shows",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/media/**",
            "$APPLOCALDATA/media/**",
            "$APPDATA/media_dev/**",
            "$APPLOCALDATA/media_dev/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDRkE4OUJCQ0YzODIyRDgKUldUWUlqalB1NG42N0lhSXYyc296VVBnK3QyS2NZZHFrSjg1Q3BlUkVQRUEyYk8xNXA0OGhNazkK",
      "endpoints": [
        "https://github.com/ChristianPayne/shows/releases/latest/download/latest.json"
      ]
    }
  }
}
